<Window x:Class="TestApp.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Админ-панель" MinHeight="450" MaxHeight="500" MinWidth="920" MaxWidth="920"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <DataGrid x:Name="dgUsers" 
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  Margin="0,0,0,55">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="50"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="130"/>
                <DataGridTextColumn Header="Пароль" Binding="{Binding Password}" Width="120"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="100"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding Last_Name}" Width="100"/>
                <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="100"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding First_Name}" Width="130"/>
                <DataGridTextColumn Header="Роль ID" Binding="{Binding Role_Id}" Width="80"/>
                <DataGridCheckBoxColumn Header="Заблокирован" Binding="{Binding IsBlocked}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right">
            <Button Content="Добавить" Width="120" Margin="5" Click="AddUser_Click"/>
            <Button Content="Сохранить" Width="130" Margin="5" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>