<Window x:Class="MilkApp.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Milk Company - Админ-панель" MinHeight="400" MinWidth="600" 
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="UserGrid" AutoGenerateColumns="False" CanUserAddRows="False" 
                  SelectionMode="Single" ItemsSource="{Binding Users}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="50"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="120"/>
                <DataGridTextColumn Header="Пароль" Binding="{Binding Password}" Width="120"/>
                <DataGridTextColumn Header="Роль" Binding="{Binding Role_Id}"  Width="120"/>
                <DataGridCheckBoxColumn Header="Заблокирован" Binding="{Binding IsBlocked}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Добавить" Width="100" Margin="5" Click="AddUser_Click"/>
            <Button Content="Блок/Разблок" Width="120" Margin="5" Click="ToggleBlock_Click"/>
            <Button Content="Сохранить" Width="100" Margin="5" Click="SaveChanges_Click"/>
        </StackPanel>
    </Grid>
</Window>