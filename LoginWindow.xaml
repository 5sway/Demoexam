<Window x:Class="DemoExam.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoExam"
        mc:Ignorable="d"
        Title="Авторизация" Height="610" Width="400" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="25">
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center">
            <Label Content="Логин"/>
            <TextBox Name="LoginTxtBox" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" Width="300" Height="25" Margin="5"/>
            <Label Content="Пароль"/>
            <PasswordBox Name="PasswordTxtBox" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" Width="300" Height="25" Margin="5"/>
            <GroupBox Header="Введите порядок капчи:- 1, 2, 3, 4" Margin="5">
                <UniformGrid Rows="2" Columns="2">
                    <Image Name="CaptchaImg1" Source="/Resources/1.png" Stretch="UniformToFill" Cursor="Hand" MouseLeftButtonDown="CaptchaImg1_MouseLeftButtonDown" Margin="2"/>
                    <Image Name="CaptchaImg2" Source="/Resources/2.png" Stretch="UniformToFill" Cursor="Hand" MouseLeftButtonDown="CaptchaImg2_MouseLeftButtonDown" Margin="2"/>
                    <Image Name="CaptchaImg3" Source="/Resources/3.png" Stretch="UniformToFill" Cursor="Hand" MouseLeftButtonDown="CaptchaImg3_MouseLeftButtonDown" Margin="2"/>
                    <Image Name="CaptchaImg4" Source="/Resources/4.png" Stretch="UniformToFill" Cursor="Hand" MouseLeftButtonDown="CaptchaImg4_MouseLeftButtonDown" Margin="2"/>
                </UniformGrid>
            </GroupBox>
            <TextBlock Name="CaptchaTxt" Text="Выбранный порядок капчи:- " Margin="5"/>
            <Button Name="LoginBtn" Content="Войти" Width="200" Height="25" Click="LoginBtn_Click"/>
        </StackPanel>
        
    </Grid>
</Window>

