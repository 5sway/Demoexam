<Window x:Class="TestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Milk Company - Вход" MinHeight="740" MinWidth="420" MaxHeight="740" MaxWidth="420"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="25">
        <StackPanel>
            <Label Content="Логин" FontWeight="SemiBold"/>
            <TextBox x:Name="LoginTextBox" Height="32" Margin="0,0,0,12" HorizontalContentAlignment="Left" VerticalContentAlignment="Center"/>

            <Label Content="Пароль" FontWeight="SemiBold"/>
            <PasswordBox x:Name="PasswordBox" Height="32" Margin="0,0,0,20" HorizontalContentAlignment="Left" VerticalContentAlignment="Center"/>

            <GroupBox Header="Капча: кликайте по картинкам в порядке 1 → 2 → 3 → 4" Margin="0,0,0,15">
                <UniformGrid Rows="2" Columns="2" Height="400">
                    <Image Source="/Resources/1.png" MouseLeftButtonDown="Captcha1_Click" Cursor="Hand" Margin="5" Stretch="UniformToFill"/>
                    <Image Source="/Resources/2.png" MouseLeftButtonDown="Captcha2_Click" Cursor="Hand" Margin="5" Stretch="UniformToFill"/>
                    <Image Source="/Resources/3.png" MouseLeftButtonDown="Captcha3_Click" Cursor="Hand" Margin="5" Stretch="UniformToFill"/>
                    <Image Source="/Resources/4.png" MouseLeftButtonDown="Captcha4_Click" Cursor="Hand" Margin="5" Stretch="UniformToFill"/>
                </UniformGrid>
            </GroupBox>

            <TextBlock x:Name="txtCaptcha" Text="Выбранный порядок: —" HorizontalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,20"/>

            <Button Content="Войти" Height="45" FontSize="16" Click="Login_Click"/>
        </StackPanel>
    </Grid>
</Window>