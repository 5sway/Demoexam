<Window x:Class="MilkApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Milk Company - Авторизация" MinHeight="915" MinWidth="715" MaxHeight="915" MaxWidth="715"
        ResizeMode="CanResizeWithGrip" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Данные для входа" Grid.Row="0" Margin="0,0,0,10">
            <StackPanel>
                <Label Content="Логин:" Target="{Binding ElementName=LoginTextBox}"/>
                <TextBox x:Name="LoginTextBox" ToolTip="Введите логин (минимум 3 символа)" Margin="0,5,0,5"/>
                <Label Content="Пароль:" Target="{Binding ElementName=PasswordBox}"/>
                <PasswordBox x:Name="PasswordBox" ToolTip="Введите пароль" Margin="0,5,0,5"/>
                <GroupBox Header="Капча: соберите по порядку слева направо" Margin="0,12,0,16">
                    <UniformGrid Rows="2" Columns="2" Height="600">
                        <Image Source="/Resources/1.png" Tag="1" MouseLeftButtonDown="CaptchaImage_MouseLeftButtonDown" Cursor="Hand" Margin="4" Stretch="UniformToFill"/>
                        <Image Source="/Resources/2.png" Tag="2" MouseLeftButtonDown="CaptchaImage_MouseLeftButtonDown" Cursor="Hand" Margin="4" Stretch="UniformToFill"/>
                        <Image Source="/Resources/3.png" Tag="3" MouseLeftButtonDown="CaptchaImage_MouseLeftButtonDown" Cursor="Hand" Margin="4" Stretch="UniformToFill"/>
                        <Image Source="/Resources/4.png" Tag="4" MouseLeftButtonDown="CaptchaImage_MouseLeftButtonDown" Cursor="Hand" Margin="4" Stretch="UniformToFill"/>
                    </UniformGrid>
                </GroupBox>
            </StackPanel>
        </GroupBox>

        <TextBlock x:Name="txtCaptchaStatus" 
           Text="Выбранный порядок: —" 
           HorizontalAlignment="Center" 
           Margin="0,0,0,16"
           FontWeight="SemiBold"/>
        <Button Content="Войти" Grid.Row="3" Height="40" VerticalAlignment="Top" Click="Login_Click"/>
    </Grid>
</Window>